# Reddit Data API credentials (optional — only needed for Reddit headline sync).
# Request access at:
# https://support.reddithelp.com/hc/en-us/requests/new?tf_42139884615700=api_request_type_developer_clone&ticket_form_id=14868593862164
#
# Copy this file to `.env` and fill in your own values. Never commit `.env`.

REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=platform:app-name:v0.1 (by /u/your_reddit_username)
