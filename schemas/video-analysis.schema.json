{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "video",
    "relevance",
    "summary",
    "facts",
    "market_moves",
    "forecasts",
    "actors",
    "companies",
    "investor_view",
    "lesson",
    "source_quality"
  ],
  "properties": {
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "source", "published", "url"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "source": { "type": "string" },
        "published": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "relevance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "include", "reason", "categories"],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "include": { "type": "boolean" },
        "reason": { "type": "string" },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 8
        }
      }
    },
    "summary": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 6
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "timestamp", "confidence"],
        "properties": {
          "claim": { "type": "string" },
          "timestamp": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      },
      "maxItems": 12
    },
    "market_moves": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset", "direction", "magnitude", "cause", "cause_type", "timestamp"],
        "properties": {
          "asset": { "type": "string" },
          "direction": { "type": "string", "enum": ["up", "down", "flat", "mixed", "unknown"] },
          "magnitude": { "type": "string" },
          "cause": { "type": "string" },
          "cause_type": { "type": "string", "enum": ["reported", "inferred", "speculative", "unknown"] },
          "timestamp": { "type": "string" }
        }
      },
      "maxItems": 12
    },
    "forecasts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "speaker",
          "horizon",
          "confidence",
          "evidence",
          "confirming_signals",
          "falsifying_signals",
          "timestamp"
        ],
        "properties": {
          "claim": { "type": "string" },
          "speaker": { "type": "string" },
          "horizon": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "evidence": { "type": "string" },
          "confirming_signals": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 5
          },
          "falsifying_signals": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 5
          },
          "timestamp": { "type": "string" }
        }
      },
      "maxItems": 10
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "objective", "constraints", "leverage", "likely_next_move", "confidence"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "objective": { "type": "string" },
          "constraints": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 5
          },
          "leverage": { "type": "string" },
          "likely_next_move": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      },
      "maxItems": 10
    },
    "companies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "ticker", "direction", "why", "thesis_impact", "metrics_to_watch"],
        "properties": {
          "name": { "type": "string" },
          "ticker": { "type": "string" },
          "direction": { "type": "string", "enum": ["winner", "loser", "mixed", "watch"] },
          "why": { "type": "string" },
          "thesis_impact": { "type": "string", "enum": ["none", "temporary", "potentially_material", "material", "unknown"] },
          "metrics_to_watch": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 6
          }
        }
      },
      "maxItems": 12
    },
    "investor_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_vs_noise", "thesis_change", "default_action", "risks", "questions"],
      "properties": {
        "signal_vs_noise": { "type": "string" },
        "thesis_change": { "type": "string" },
        "default_action": { "type": "string", "enum": ["observe", "research", "review_position", "no_action"] },
        "risks": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 6
        },
        "questions": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 6
        }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["concept", "plain_english", "example", "quiz"],
      "properties": {
        "concept": { "type": "string" },
        "plain_english": { "type": "string" },
        "example": { "type": "string" },
        "quiz": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 3
        }
      }
    },
    "source_quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caption_risk", "promotional_risk", "missing_context", "notes"],
      "properties": {
        "caption_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "promotional_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "missing_context": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "string" }
      }
    }
  }
}
